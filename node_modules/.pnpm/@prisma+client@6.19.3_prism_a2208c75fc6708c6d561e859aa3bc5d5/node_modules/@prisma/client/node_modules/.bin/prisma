#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../../prisma@7.6.0_@types+react-d_8fb3400b0b0a527553c73d4e38ca4eaf/node_modules/prisma/build/index.js" "$@"
else
  exec node  "$basedir/../../../../../../prisma@7.6.0_@types+react-d_8fb3400b0b0a527553c73d4e38ca4eaf/node_modules/prisma/build/index.js" "$@"
fi
