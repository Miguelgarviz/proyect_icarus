// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Player {
  id Int @default(autoincrement()) @id
  ship Ship?
  storage Storage?
  cards Cards[]
  movement Int
  name String
  color String

  lobby Lobby? @relation(fields: [lobbyId], references: [id])
  lobbyId Int?
}

model Ship{
  id Int @default(autoincrement()) @id

  shield Int @default(10)
  drill Int @default(10)
  engine Int @default(3)
  positionX Int? @default(0)
  positionY Int? @default(0)

  player Player? @relation(fields: [playerId], references: [id])
  playerId Int? @unique 
}

model Storage{
  id Int @default(autoincrement()) @id

  green Int @default(0)
  red Int @default(0)
  yellow Int @default(0)

  player Player? @relation(fields: [playerId], references: [id])
  playerId Int? @unique 
}

enum CardType {
  TEMPORARY_PATCH
  NEW_DRILL
  BACKUP_POWER
  SLINGSHOT
  ENHANCED_SCANNER
  ROCKET_THRUSTERS
}

model Cards {
  id Int @default(autoincrement()) @id

  player Player? @relation(fields: [playerId], references: [id])
  playerId Int?

  store Store? @relation(fields: [storeId], references: [id])
  storeId Int?

  cost Int
  type CardType
}

model Store{
  id Int @default(autoincrement()) @id

  numCards Int @default(18)
  cards Cards[]

  game Game?
}

enum TileType {
  EMPTY
  GREEN
  RED
  YELLOW
  SPACE_STATION
  START
}

model Tile{
  id Int @default(autoincrement()) @id

  type TileType
  positionX Int
  positionY Int

  game Game? @relation(fields: [gameId], references: [id])
  gameId Int?
}

enum Dificulty {
  BEGINNER_I
  BEGINNER_II
  EASY_I
  EASY_II
  MEDIUM_I
  MEDIUM_II
  HARD_I
  HARD_II
  EXTREME_I
  EXTREME_II
  IMPOSSIBLE
}

model Lobby {
  id Int @default(autoincrement()) @id

  dificulty Dificulty
  numPlayers Int
  players Player[]

  game Game?
}

model Game {
  id Int @default(autoincrement()) @id

  lobby Lobby? @relation(fields: [lobbyId], references: [id])
  lobbyId Int? @unique
  round Int @default(0)
  actualPlayerId Int?
  supernovaLvL Int @default(0)

  store Store? @relation(fields: [storeId], references: [id])
  storeId Int? @unique

  tiles Tile[]
  drillCards drillCard[]
}

model drillCard {
  id Int @default(autoincrement()) @id

  greenResources Int @default(0)
  redResources Int @default(0)
  yellowResources Int @default(0)

  isSupernovaCard Boolean @default(false)

  game Game? @relation(fields: [gameId], references: [id])
  gameId Int?
}
